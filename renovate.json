{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  // 1. 允许 pnpm 运行，或者直接删除此行让 bot 自动检测
  "enabledManagers": ["npm", "pnpm"], 
  "timezone": "Asia/Shanghai",
  "schedule": ["before 8am on Sunday"],

  "vulnerabilityAlerts": {
    "enabled": true,
    // 2. 改为 null，确保安全更新不受周日时间的限制
    "schedule": null 
  },
  
  // 3. 允许自动修复深层传递依赖的漏洞
  "transitiveRemediation": true,

  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "matchPackageNames": ["next"],
      "allowedVersions": "<17.0.0"
    },
    {
      "matchPackageNames": ["react", "react-dom"],
      "allowedVersions": "<20.0.0"
    },
    {
      "matchPackageNames": ["tailwindcss", "postcss", "autoprefixer", "@tailwindcss/typography"],
      "allowedVersions": "<4.0.0"
    }
  ],
  "rangeStrategy": "bump",
  "postUpdateOptions": ["pnpmDedupe"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0
}
