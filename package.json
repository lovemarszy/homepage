{
  "name": "loveur.life",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prod": "next build",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
